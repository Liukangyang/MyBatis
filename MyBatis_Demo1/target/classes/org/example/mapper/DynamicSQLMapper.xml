<!--    choose/when/otherwise标签-->
    <select id="getEmpByCondition" resultMap="EmpMap">
        select * from emp
        <where>
            <choose>
                <when test="name!=null and name!=''">
                    emp_name = #{name}
                </when>
                <when test="telecom != null and telecom!=''">
                    emp_telecom = #{telecom}
                </when>
                <otherwise>
                    did = 2
                </otherwise>
            </choose>
        </where>
    </select>


<!--    foreach-->
<!--    int insertMultiEmps(@Param("emps") List<Emp> emps);-->
    <insert id="insertMultiEmps">
       insert into emp values
        <foreach collection="emps" item="emp" separator=",">
            (null,#{emp.name},#{emp.telecom},${emp.did})
        </foreach>
    </insert>

